#!/bin/bash
# SPDX-License-Identifier: MIT OR Apache-2.0
# Copyright (c) 2026 dravr.ai
# ABOUTME: Pre-push hook — runs clippy inline or checks validation marker
# ABOUTME: Works for all dravr-* repos whether they have pre-push-validate.sh or not

set -e

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
GIT_DIR="$(git rev-parse --git-dir)"
MARKER_FILE="$GIT_DIR/validation-passed"
VALIDATION_TTL_MINUTES=15
VALIDATE_SCRIPT="$PROJECT_ROOT/scripts/ci/pre-push-validate.sh"

# If the project has pre-push-validate.sh, enforce the marker system.
# Otherwise, run an inline clippy gate scoped to changed crates.
if [ -f "$VALIDATE_SCRIPT" ]; then
    # ---- Marker-based validation (dravr-platform and similar) ----
    if [ ! -f "$MARKER_FILE" ]; then
        echo ""
        echo "BLOCKED: No validation marker found."
        echo ""
        echo "Run before pushing:"
        echo "  ./scripts/ci/pre-push-validate.sh"
        echo ""
        exit 1
    fi

    read -r MARKER_TIME MARKER_COMMIT < "$MARKER_FILE"
    CURRENT_COMMIT=$(git rev-parse HEAD)
    CURRENT_TIME=$(date +%s)

    if [ "$MARKER_COMMIT" != "$CURRENT_COMMIT" ]; then
        echo ""
        echo "BLOCKED: Validation marker is for a different commit."
        echo "  Marker:  ${MARKER_COMMIT:0:12}"
        echo "  Current: ${CURRENT_COMMIT:0:12}"
        echo ""
        echo "Re-run: ./scripts/ci/pre-push-validate.sh"
        echo ""
        exit 1
    fi

    ELAPSED=$(( CURRENT_TIME - MARKER_TIME ))
    TTL_SECONDS=$(( VALIDATION_TTL_MINUTES * 60 ))

    if [ "$ELAPSED" -gt "$TTL_SECONDS" ]; then
        ELAPSED_MIN=$(( ELAPSED / 60 ))
        echo ""
        echo "BLOCKED: Validation marker expired (${ELAPSED_MIN}m old, max ${VALIDATION_TTL_MINUTES}m)."
        echo ""
        echo "Re-run: ./scripts/ci/pre-push-validate.sh"
        echo ""
        exit 1
    fi

    echo "Validation marker OK (${ELAPSED}s old, commit ${CURRENT_COMMIT:0:12})"
    exit 0
fi

# ---- Inline validation (fallback for repos without pre-push-validate.sh) ----
[ ! -f "$PROJECT_ROOT/Cargo.toml" ] && exit 0

cd "$PROJECT_ROOT"

echo "Pre-push: cargo fmt --check..."
if ! cargo fmt --all -- --check > /dev/null 2>&1; then
    echo "BLOCKED: Code not formatted. Run: cargo fmt --all"
    exit 1
fi

# Detect whether this is a Cargo workspace with crates/ layout
IS_WORKSPACE=false
if grep -q "^\[workspace\]" "$PROJECT_ROOT/Cargo.toml" 2>/dev/null && [ -d "$PROJECT_ROOT/crates" ]; then
    IS_WORKSPACE=true
fi

if [ "$IS_WORKSPACE" = true ]; then
    # Workspace: scope clippy to crates whose files changed (fast local gate).
    # CI runs full workspace clippy — this is intentionally narrower.
    CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
    if git rev-parse --verify "origin/$CURRENT_BRANCH" &>/dev/null; then
        BASE_REF="origin/$CURRENT_BRANCH"
    elif git rev-parse --verify "origin/main" &>/dev/null; then
        BASE_REF="origin/main"
    else
        BASE_REF="HEAD~1"
    fi
    CHANGED_FILES=$(git diff --name-only "$BASE_REF" HEAD 2>/dev/null || echo "")

    # Collect unique changed crate directories (bash 3.2 compatible — no associative arrays)
    CHANGED_CRATES=""
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        case "$file" in
            crates/*)
                crate_dir="${file#crates/}"
                crate_dir="${crate_dir%%/*}"
                if [ -n "$crate_dir" ] && [ -d "$PROJECT_ROOT/crates/$crate_dir" ]; then
                    case " $CHANGED_CRATES " in
                        *" $crate_dir "*) ;;
                        *) CHANGED_CRATES="$CHANGED_CRATES $crate_dir" ;;
                    esac
                fi
                ;;
        esac
    done <<< "$CHANGED_FILES"

    CHANGED_CRATES="${CHANGED_CRATES# }"

    if [ -z "$CHANGED_CRATES" ]; then
        echo "Pre-push: no crate changes detected, skipping clippy (CI will run full workspace clippy)"
    else
        for crate_dir in $CHANGED_CRATES; do
            crate_toml="$PROJECT_ROOT/crates/$crate_dir/Cargo.toml"
            pkg=$(grep -m1 '^name[[:space:]]*=' "$crate_toml" 2>/dev/null | sed -E 's/name[[:space:]]*=[[:space:]]*"([^"]+)".*/\1/')
            [ -z "$pkg" ] && pkg="$crate_dir"
            echo "Pre-push: clippy -p $pkg --all-targets --all-features"
            if ! cargo clippy -p "$pkg" --all-targets --all-features -- -D warnings; then
                echo ""
                echo "BLOCKED: Clippy failed for $pkg. Fix warnings before pushing."
                exit 1
            fi
        done
    fi
else
    # Single-crate repo — full clippy is the per-crate case.
    echo "Pre-push: cargo clippy --all-targets --all-features..."
    if ! cargo clippy --all-targets --all-features -- -D warnings 2>&1; then
        echo ""
        echo "BLOCKED: Clippy failed. Fix all warnings before pushing."
        exit 1
    fi
fi

echo "Pre-push: OK"
